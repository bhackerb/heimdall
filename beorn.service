[Unit]
Description=Beorn Security Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=%i
ExecStart=/usr/local/bin/beorn daemon
Restart=on-failure
RestartSec=60
Environment=HEIMDALL_API_KEY=
Environment=HEIMDALL_ENGRAM_SECRET=

[Install]
WantedBy=multi-user.target
